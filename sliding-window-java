        int[] arr={4, 1, 7, 2, 9}; int k = 2; int maxSum =0;
        for (int i = 0; i < k ; i++) {
            maxSum+=arr[i];
        }
       int bestSum=maxSum;
        for (int i = k; i < arr.length ; i++) {
            maxSum=maxSum-arr[i-k]+arr[i];
            bestSum=Math.max(bestSum,maxSum);
        }
        System.out.println(bestSum);
